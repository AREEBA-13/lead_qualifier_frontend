        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.4,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"You are a lead qualification assistant for a business. Analyze this inquiry and respond with ONLY valid JSON, no markdown fences, in exactly this shape: {\\\"score\\\": \\\"hot|warm|cold\\\", \\\"reason\\\": \\\"one sentence why\\\", \\\"reply\\\": \\\"a short, warm, personalized email reply (2-4 sentences) addressed to the person by name, thanking them and responding to their specific message\\\"}.\\n\\nScoring rules: hot = clear buying intent, budget mentioned, urgent need, or asks for a call/quote. warm = genuine interest but vague or early stage. cold = spam, job seekers, vendors selling to us, or irrelevant.\\n\\nLead details:\\nName: \" + ($json.body.name || 'Unknown') + \"\\nEmail: \" + ($json.body.email || 'Unknown') + \"\\nCompany: \" + ($json.body.company || 'Not given') + \"\\nMessage: \" + ($json.body.message || '')\n  }]\n}) }}",
        "options": {}
      },
      "id": "372cbc53-c81d-449f-a43a-0f856e67fc4a",
      "name": "AI Qualify Lead (Gemini)1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1392,
        464
      ]
    },
    {
      "parameters": {
        "jsCode": "// Get the AI's raw text answer\nconst aiText = $json.choices?.[0]?.message?.content || '{}';\n\n// Strip markdown fences if the model added them\nconst clean = aiText.replace(/```json/gi, '').replace(/```/g, '').trim();\n\nlet ai;\ntry {\n  ai = JSON.parse(clean);\n} catch (e) {\n  ai = { score: 'warm', reason: 'AI response could not be parsed, defaulted to warm', reply: 'Thank you for reaching out! We received your message and will get back to you shortly.' };\n}\n\n// Merge with the original lead data from the webhook\nconst lead = $('Lead Webhook1').first().json.body || {};\n\nreturn [{\n  json: {\n    name: lead.name || 'Unknown',\n    email: lead.email || '',\n    company: lead.company || '',\n    message: lead.message || '',\n    score: (String(ai.score || 'warm')).toLowerCase().trim().replace(/[^a-z]/g, ''),\n    reason: ai.reason || '',\n    reply: ai.reply || '',\n    receivedAt: new Date().toISOString()\n  }\n}];"
      },
