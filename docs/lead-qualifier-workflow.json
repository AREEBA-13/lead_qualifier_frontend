        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  \"content\": \"🔥 **HOT LEAD ALERT!**\",\n  \"embeds\": [{\n    \"title\": \"🔥 \" + $('Parse AI Result1').first().json.name + \" — \" + ($('Parse AI Result1').first().json.company || 'No company'),\n    \"color\": 15548997,\n    \"fields\": [\n      { \"name\": \"📧 Email\", \"value\": $('Parse AI Result1').first().json.email || 'n/a', \"inline\": true },\n      { \"name\": \"🎯 Score\", \"value\": $('Parse AI Result1').first().json.score.toUpperCase(), \"inline\": true },\n      { \"name\": \"💬 Message\", \"value\": ($('Parse AI Result1').first().json.message || '').slice(0, 1000) },\n      { \"name\": \"🤖 Why hot\", \"value\": $('Parse AI Result1').first().json.reason || 'n/a' }\n    ],\n    \"footer\": { \"text\": \"⚡ Follow up ASAP! — Lead Qualifier bot\" }\n  }]\n}) }}",
        "options": {}
      },
